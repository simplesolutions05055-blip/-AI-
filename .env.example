# ── Vercel env: ONLY Supabase keys + the two internal vars ──────────────────
# Provider keys (OpenAI / Resend / Twilio) live ONLY in Supabase Edge Function
# secrets — set them with `supabase secrets set ...`, NOT here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# must match the INTERNAL_API_SECRET Supabase secret
INTERNAL_API_SECRET=
APP_URL=http://localhost:3000
NODE_ENV=development
